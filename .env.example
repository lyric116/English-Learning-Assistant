PORT=3001
NODE_ENV=development

# AI request timeout in milliseconds
AI_REQUEST_TIMEOUT_MS=45000

# Security
ALLOW_PRIVATE_AI_HOSTS=0
ALLOWED_AI_HOSTS=api.openai.com,api.deepseek.com

# Provider strategy
# Daily quota for the primary provider passed by client aiConfig
AI_PROVIDER_PRIMARY_DAILY_QUOTA=2000
# Daily quota default used by fallback providers if `dailyQuota` missing
AI_PROVIDER_FALLBACK_DAILY_QUOTA=500
# JSON array of fallback providers
# AI_FALLBACK_PROVIDERS=[{"name":"backup-openai","baseUrl":"https://api.openai.com/v1","apiKey":"sk-***","model":"gpt-4o-mini","dailyQuota":300}]
AI_FALLBACK_PROVIDERS=
